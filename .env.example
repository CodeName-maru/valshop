# Riot Authentication Configuration
# Redirect URI for Riot OAuth callback
# Development: http://localhost:3000/api/auth/callback
# Production: https://<your-domain>/api/auth/callback
RIOT_AUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session Encryption Key (owned by Plan 0002)
# Base64-encoded 32-byte key for AES-GCM encryption
# Generate with: openssl rand -base64 32
TOKEN_ENC_KEY=your-base64-encoded-32-byte-key-here
