# Environment Variables for VAL-Shop
# Copy this file to .env.local and fill in the values

# ============================================================================
# Core (MVP)
# ============================================================================

# AES-GCM encryption key for session tokens (server-side only)
# Generate with: openssl rand -base64 32
TOKEN_ENC_KEY=

# AES-GCM encryption key for MFA pending cookie (server-side only)
# Distinct from TOKEN_ENC_KEY — rotating one must not affect the other.
# Generate with: openssl rand -base64 32
PENDING_ENC_KEY=

# Application origin for CSRF / Origin-header validation on /api/auth/*
# Development: http://localhost:3000
# Production: https://<your-domain>
APP_ORIGIN=http://localhost:3000

# Riot Client Version (for X-Riot-ClientVersion header)
# Defaults to RiotClient/60.0.6.4770705.4749685 rso-auth (Windows;10;;Professional, x64)
# Override only if Riot updates the client version requirement
RIOT_CLIENT_USER_AGENT=RiotClient/60.0.6.4770705.4749685 rso-auth (Windows;10;;Professional, x64)

# Auth mode for fallback strategy
# "credentials" (default): Use credentials-based auth (username/password)
# "manual-ssid": Fallback to manual SSID input when α' (alpha prime) auth fails
# See spec § 11 Fallback for details
AUTH_MODE=credentials

# ============================================================================
# Phase 2: Supabase (Database + Auth)
# ============================================================================

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous key (client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-side, worker only)
# IMPORTANT: Never expose this to client-side code
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# Phase 2: Email Notifications (Resend)
# ============================================================================

# Resend API key for sending emails
RESEND_API_KEY=

# From email address for notifications (must be verified in Resend)
RESEND_FROM_EMAIL=

# ============================================================================
# Phase 2: Cron Worker Security
# ============================================================================

# Secret for cron endpoint authentication
# Generate with: openssl rand -base64 32
CRON_SECRET=
