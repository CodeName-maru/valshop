# Environment Variables for VAL-Shop
# Copy this file to .env.local and fill in the values

# ============================================================================
# Core (MVP)
# ============================================================================

# AES-GCM encryption key for session tokens (server-side only)
# Generate with: openssl rand -base64 32
TOKEN_ENC_KEY=

# ============================================================================
# Phase 2: Supabase (Database + Auth)
# ============================================================================

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous key (client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-side, worker only)
# IMPORTANT: Never expose this to client-side code
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# Phase 2: Email Notifications (Resend)
# ============================================================================

# Resend API key for sending emails
RESEND_API_KEY=

# From email address for notifications (must be verified in Resend)
RESEND_FROM_EMAIL=

# ============================================================================
# Phase 2: Cron Worker Security
# ============================================================================

# Secret for cron endpoint authentication
# Generate with: openssl rand -base64 32
CRON_SECRET=
